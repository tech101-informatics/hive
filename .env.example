# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/projecthub?retryWrites=true&w=majority

# Slack Incoming Webhook URL (for channel messages)
# Get this from: https://api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXXXXXX/XXXXXXXXX/XXXXXXXXXXXXXXXXXXXXXXXX

# Slack Bot Token (for DMs, user lookup, and channel messages via API)
# Get this from: https://api.slack.com/apps → Your App → OAuth & Permissions
# Required scopes: chat:write, users:list, users:read.email
SLACK_BOT_TOKEN=xoxb-XXXXXXXXXXXX-XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXX

# Slack Channel ID for project-wide notifications (e.g., #project-updates)
# Right-click channel → View channel details → copy Channel ID at bottom
SLACK_CHANNEL_ID=C0XXXXXXXXX

# Slack Signing Secret (for verifying /hive slash command requests)
# Get this from: https://api.slack.com/apps → Your App → Basic Information → App Credentials
SLACK_SIGNING_SECRET=your-signing-secret-here

# App URL (used in Slack messages for card links)
APP_URL=https://your-app.vercel.app

# Cron secret — protects cron endpoints from unauthorized access
CRON_SECRET=your-random-cron-secret-here

# Auth — NextAuth.js + Google OAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-here
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Domain restriction — only allow emails from this domain (leave empty to allow all)
ALLOWED_DOMAIN=mycompany.com
# Also set this for the auth-error page to display the domain name
NEXT_PUBLIC_ALLOWED_DOMAIN=mycompany.com

# Admin emails — comma-separated list of admin users
ADMIN_EMAILS=alice@mycompany.com,bob@mycompany.com

# --- Support ticket integration ---

# Shared secret used by the dashboard server to HMAC-sign requests to
# /api/dashboard/support-requests. Generate a long random string (e.g. `openssl rand -hex 32`).
# The dashboard signs `${timestamp}.${pathWithQuery}.${rawBody}` with HMAC-SHA256
# and sends `X-Hive-Timestamp` + `X-Hive-Signature` headers.
SUPPORT_HMAC_SECRET=your-long-random-shared-secret

# Cloudflare Turnstile secret key (server-side) used to verify captcha tokens
# from the public landing-page form at /api/public/support-requests.
# Get from: https://dash.cloudflare.com → Turnstile → your site → Settings.
TURNSTILE_SECRET_KEY=0xAAAAAAAAAAAAAAAAAAAAAAAA

# Optional: dedicated Slack channel for support-ticket notifications.
# Falls back to SLACK_CHANNEL_ID if unset.
SUPPORT_SLACK_CHANNEL_ID=C0XXXXXXXXX

# CORS allowlist for the public landing-page endpoint (POST /api/public/support-requests).
# Comma-separated list of origins. Use `*` for dev only.
SUPPORT_PUBLIC_CORS_ORIGINS=http://localhost:3001,https://storepecker.com

# CORS allowlist for the HMAC-signed dashboard endpoints (DEV/TESTING ONLY).
# Production calls should be server-to-server (no Origin header → no CORS check).
# Setting this implies the HMAC secret is exposed in a browser bundle, which lets
# anyone forge tickets as any user. Leave empty in production.
SUPPORT_DASHBOARD_CORS_ORIGINS=http://localhost:3001
